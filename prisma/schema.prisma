// Prisma schema for Lengger Ledger Converter
// Local-only deployment, SQLite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Optional: log each conversion for audit/history. Not required for the
/// converter to function (xlsx is generated on-demand, never stored).
model ConversionLog {
  id          String   @id @default(cuid())
  filename    String
  rowsCount   Int
  userEmail   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
